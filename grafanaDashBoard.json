{
    "dashboard": {
        "id": null,
        "uid": null,
        "title": "Load Balancer Performance",
        "tags": [
            "performance",
            "monitoring"
        ],
        "timezone": "browser",
        "schemaVersion": 36,
        "version": 1,
        "refresh": "5s",
        "panels": [
            {
                "title": "Total Requests Over Time",
                "type": "timeseries",
                "gridPos": {
                    "x": 0,
                    "y": 0,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "total_requests_total",
                        "legendFormat": "Total Requests",
                        "refId": "A"
                    }
                ]
            },
            {
                "title": "Requests Per Second",
                "type": "timeseries",
                "gridPos": {
                    "x": 12,
                    "y": 0,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "rate(total_requests_total[1m])",
                        "legendFormat": "RPS",
                        "refId": "B"
                    }
                ]
            },
            {
                "title": "95th Percentile Request Duration",
                "type": "timeseries",
                "gridPos": {
                    "x": 0,
                    "y": 6,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
                        "legendFormat": "p95 Request Duration",
                        "refId": "C"
                    }
                ]
            },
            {
                "title": "Average Response Time",
                "type": "gauge",
                "gridPos": {
                    "x": 12,
                    "y": 6,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "rate(flask_http_request_duration_seconds_sum[1m]) / rate(flask_http_request_duration_seconds_count[1m])",
                        "legendFormat": "Avg Response Time",
                        "refId": "D"
                    }
                ]
            },
            {
                "title": "HTTP Status Codes Breakdown",
                "type": "piechart",
                "gridPos": {
                    "x": 0,
                    "y": 12,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "count by (status) (flask_http_request_total)",
                        "legendFormat": "{{status}}",
                        "refId": "E"
                    }
                ]
            },
            {
                "title": "Garbage Collection Events",
                "type": "timeseries",
                "gridPos": {
                    "x": 12,
                    "y": 12,
                    "w": 12,
                    "h": 6
                },
                "targets": [
                    {
                        "expr": "rate(python_gc_collections_total[5m])",
                        "legendFormat": "GC Events",
                        "refId": "F"
                    }
                ]
            }
        ]
    },
    "overwrite": true
}